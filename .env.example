NODE_ENV=development
PORT=3002
APP_NAME=BackendToolkit
APP_URL=http://localhost:3002

# Database
MONGODB_URI=mongodb://localhost:27017/BackendToolkitCluster

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Email (new)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=@gmail.com
EMAIL_PASS=app-password
EMAIL_FROM=@gmail.com

# JWT
JWT_SECRET=secret key 32 bytes long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=secret key 64 bytes
JWT_REFRESH_EXPIRES_IN=30d

# Paystack
PAYSTACK_SECRET_KEY=pk_test_your-paystack-key

# Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png

# Cloudinary (Optional - uses local storage if not provided)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=uploads

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key-here12345678 
ENCRYPTION_IV=your-16-char-iv-here1234

# Optional
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
ELASTIC_APM_SERVER_URL=
ELASTIC_APM_SECRET_TOKEN=
UNLEASH_URL=
UNLEASH_INSTANCE_ID=

# Twilio (for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
